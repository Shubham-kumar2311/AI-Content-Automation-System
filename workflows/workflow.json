        "jsonBody": "={\n  \"model\": \"openai/gpt-oss-120b:free\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an elite Instagram reel strategist and viral content analyst. Your job is to analyze short-form content performance psychology, hooks, storytelling, pacing, emotional triggers, retention mechanisms, and viral potential.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this Instagram Reel transcript.\\n\\nTranscript:\\n{{$json.text}}\\n\\nReturn ONLY valid JSON in this exact structure:\\n\\n{\\n  \\\"hook_type\\\": \\\"\\\",\\n  \\\"hook_strength\\\": 0,\\n  \\\"why_hook_works\\\": \\\"\\\",\\n  \\\"emotional_triggers\\\": [],\\n  \\\"retention_strategies\\\": [],\\n  \\\"storytelling_structure\\\": \\\"\\\",\\n  \\\"viral_mechanics\\\": [],\\n  \\\"target_audience\\\": [],\\n  \\\"viral_potential_score\\\": 0,\\n  \\\"improvements\\\": [],\\n  \\\"better_hook_suggestions\\\": [],\\n  \\\"cta_quality\\\": \\\"\\\",\\n  \\\"content_style\\\": \\\"\\\",\\n  \\\"niche\\\": \\\"\\\",\\n  \\\"summary\\\": \\\"\\\"\\n}\\n\\nRules:\\n- Return ONLY JSON\\n- No markdown\\n- No explanation text\\n- Scores must be between 1-10\\n- Arrays must always be arrays\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
