      "id": "5d2dcc9b-ba12-4219-8688-68def2f75e55",
      "name": "Hook Analysis"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const data = JSON.parse(item.json.choices[0].message.content);\n\n  return {\n    json: {\n\n      hook_type: data.hook_type || \"\",\n      hook_strength: data.hook_strength || 0,\n      why_hook_works: data.why_hook_works || \"\",\n\n      emotional_triggers: (data.emotional_triggers || []).join(\", \"),\n      retention_strategies: (data.retention_strategies || []).join(\", \"),\n      storytelling_structure: data.storytelling_structure || \"\",\n\n      viral_mechanics: (data.viral_mechanics || []).join(\", \"),\n      target_audience: (data.target_audience || []).join(\", \"),\n\n      viral_potential_score: data.viral_potential_score || 0,\n\n      improvements: (data.improvements || []).join(\" | \"),\n      better_hook_suggestions: (data.better_hook_suggestions || []).join(\" | \"),\n\n      cta_quality: data.cta_quality || \"\",\n      content_style: data.content_style || \"\",\n      niche: data.niche || \"\",\n      summary: data.summary || \"\"\n    }\n  };\n});"
      },
